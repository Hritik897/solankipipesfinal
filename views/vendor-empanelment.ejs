<%- include('partials/header') %>

<header class="py-16 px-8 max-w-7xl mx-auto text-center">
    <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-black mb-4">
        VENDOR <span class="font-light">EMPANELMENT</span>
    </h1>
    <p class="text-xl md:text-2xl font-light mt-2 text-gray-700">Join our growing network of distributors and partners</p>
</header>

<main class="max-w-7xl mx-auto px-8 py-10 mb-20">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        
        <div>
            <h2 class="text-3xl font-bold mb-6 text-blue-900">Current Empanelment List</h2>
            <p class="text-gray-700 mb-8 leading-relaxed">
                Solanki Industries is proud to be empanelled and approved by various government departments, water boards, and private infrastructural companies across North India. We are continuously expanding our reach to serve more regions efficiently.
            </p>
            <ul class="list-disc pl-5 space-y-3 text-gray-800 font-semibold">
                <li>Dakshin Haryana Bijli Vitran Nigam Limited (DHBVN) - Haryana (Underground HDPE Pipe Category)</li>
                <li>Public Health Engineering Department (PHED) - Haryana</li>
                <li>Water Supply & Sanitation Departments</li>
                <li>Panchayati Raj Institutions</li>
                <li>Major EPC Contractors</li>
                <li>Agriculture and Irrigation Departments</li>
            </ul>
        </div>

        <div class="bg-gray-50 p-8 rounded-xl border border-gray-200">
            <h2 class="text-2xl font-bold mb-6 text-blue-900">Distributor / Vendor Application</h2>
            <form action="mailto:sales@solankipipes.com" method="post" enctype="text/plain" class="grid grid-cols-1 gap-6">
                <div>
                    <input type="text" name="Company Name" required placeholder="COMPANY NAME *" class="w-full border border-gray-300 rounded py-3 px-4 focus:outline-none focus:border-blue-500 text-sm placeholder-gray-400">
                </div>
                <div>
                    <input type="text" name="Contact Person" required placeholder="CONTACT PERSON *" class="w-full border border-gray-300 rounded py-3 px-4 focus:outline-none focus:border-blue-500 text-sm placeholder-gray-400">
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <input type="email" name="Email" required placeholder="EMAIL *" class="w-full border border-gray-300 rounded py-3 px-4 focus:outline-none focus:border-blue-500 text-sm placeholder-gray-400">
                    <input type="text" name="Mobile" required placeholder="MOBILE *" class="w-full border border-gray-300 rounded py-3 px-4 focus:outline-none focus:border-blue-500 text-sm placeholder-gray-400">
                </div>
                <div>
                    <input type="text" name="City/State" required placeholder="CITY / STATE *" class="w-full border border-gray-300 rounded py-3 px-4 focus:outline-none focus:border-blue-500 text-sm placeholder-gray-400">
                </div>
                <div>
                    <select name="Application Type" class="w-full border border-gray-300 rounded py-3 px-4 focus:outline-none focus:border-blue-500 text-sm text-gray-500">
                        <option value="" disabled selected>APPLICATION TYPE</option>
                        <option value="Distributorship">Distributorship</option>
                        <option value="Dealership">Dealership</option>
                        <option value="Raw Material Vendor">Raw Material Vendor</option>
                    </select>
                </div>
                <div>
                    <textarea name="Message" placeholder="BRIEF ABOUT YOUR BUSINESS" rows="4" class="w-full border border-gray-300 rounded py-3 px-4 focus:outline-none focus:border-blue-500 text-sm placeholder-gray-400 resize-none"></textarea>
                </div>
                
                <div class="pt-2">
                    <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white rounded-lg w-full h-12 flex items-center justify-center shadow-lg transition duration-300">
                        <span class="text-sm font-bold uppercase tracking-wider">Submit Application</span>
                    </button>
                </div>
            </form>
        </div>

    </div>
</main>

<%- include('partials/footer') %>
