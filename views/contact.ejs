 <%- include('partials/header') %>

    <header class="py-16 px-8 max-w-7xl mx-auto text-center">
        <h1 class="text-4xl md:text-8xl font-bold tracking-tight text-black mb-4">
            CONTACTING <span class="font-light">SOLANKI </span>
        </h1>
        <p class="text-3xl md:text-6xl font-light mt-2 text-gray-700">First Step to Excellence.</p>
    </header>

    <main class="max-w-7xl mx-auto px-8 py-10">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 border-t border-gray-100 pt-12 mb-20">
            <div>
                <h3 class="font-bold text-xs uppercase tracking-widest text-blue-900 mb-4">Head Office</h3>
                <p class="font-bold text-sm mb-2 uppercase">Solanki Pipes Pvt. Ltd.</p>
                <p class="text-xs leading-relaxed text-gray-600">
                    Fatehabad Road, Mehuwala,<br>
                    Fatehabad - 125053, Haryana, India.
                
                <div class="mt-4 flex items-center">
                    <div class="w-8 h-8 bg-blue-500 rounded-sm flex items-center justify-center mr-2">
                        <span class="text-white font-bold text-xs">SP</span>
                    </div>
                    <span class="font-bold text-sm">Solanki Pipes</span>
                </div>
            </div>

            <div>
                <h3 class="font-bold text-xs uppercase tracking-widest text-blue-900 mb-4">Phone</h3>
                <p class="text-xs text-gray-600 mb-6">99921-77822 |  94664-58070  
                    <br/> 94667-77822  | 98128-77822  </p>
                
                <h3 class="font-bold text-xs uppercase tracking-widest text-blue-900 mb-4">Email</h3>
                <p class="text-xs text-gray-600">sales@solankipipes.com</p>
            </div>

            <div class="flex flex-col items-center md:items-end">
                <h3 class="font-bold text-xs uppercase tracking-widest text-blue-900 mb-4">Follow Us</h3>
                <div class="flex space-x-4 mb-8">
                    <a href="#" class="text-gray-600 hover:text-blue-600"><i class="fab fa-facebook-f"></i></a>
                    <a href="#" class="text-gray-600 hover:text-blue-600"><i class="fab fa-instagram"></i></a>
                    <a href="#" class="text-gray-600 hover:text-blue-600"><i class="fab fa-linkedin-in"></i></a>
                </div>
                <div class="text-right text-[10px] uppercase font-bold flex space-x-4">
                    <a href="#">Home</a>
                    <a href="#">About Us</a>
                    <a href="#">Products</a>
                    <a href="#">Quality</a>
                    <a href="#" class="text-blue-600">Contact Us</a>
                </div>
            </div>
        </div>

        <div class="max-w-7xl">
            <h2 class="text-3xl md:text-6xl font-bold leading-tight mb-12 text-center">
                LET'S BEGIN TOGETHER<br>FOR A NEW PROJECT PIPELINE
            </h2>
            
            <form class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-10">
                <div class="relative">
                    <input type="text" placeholder="NAME" class="w-full border-b border-gray-300 py-4 px-4 focus:outline-none focus:border-blue-500 text-xs placeholder-gray-400">
                </div>
                <div class="relative">
                    <input type="email" placeholder="EMAIL" class="w-full border-b border-gray-300 py-4  px-4  focus:outline-none focus:border-blue-500 text-xs placeholder-gray-400">
                </div>
                <div class="relative">
                    <input type="text" placeholder="PHONE NUMBER" class="w-full border-b border-gray-300 py-4   px-4  focus:outline-none focus:border-blue-500 text-xs placeholder-gray-400">
                </div>
                <div class="relative">
                    <input type="text" placeholder="SUBJECT/REQUIREMENT" class="w-full border-b border-gray-300 py-4   px-4  focus:outline-none focus:border-blue-500 text-xs placeholder-gray-400">
                </div>
                <div class="md:col-span-2 relative">
                    <input type="text" placeholder="MESSAGE" class="w-full border-b border-gray-300 py-4  px-4  focus:outline-none focus:border-blue-500 text-xs placeholder-gray-400">
                </div>
                
                <div class="pt-4">
                    <button class="bg-blue-600 hover:bg-blue-700 text-white rounded-lg w-full h-12 flex items-center justify-center shadow-lg transition duration-300">
                        <span class="text-[10px] font-bold">Submit</span>
                    </button>
                </div>
            </form>
        </div>
    </main>

