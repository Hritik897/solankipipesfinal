                    <a href="/quality">Quality</a>
                    <a href="/contact" class="text-blue-600">Contact Us</a>
                </div>
            </div>
        </div>

        <div class="max-w-7xl mt-12">
            <h2 class="text-3xl md:text-6xl font-bold leading-tight mb-12 text-center uppercase tracking-tight">
                LET'S BEGIN TOGETHER<br>FOR A NEW PROJECT PIPELINE
            </h2>
            
            <form class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-10 bg-white p-8 md:p-12 rounded-3xl border border-gray-100 shadow-sm relative">
                <div class="relative">
                    <input type="text" name="FullName" required placeholder="FULL NAME *" class="w-full border-b border-gray-300 py-4 px-4 focus:outline-none focus:border-blue-500 text-xs placeholder-gray-400 bg-transparent">
                </div>
                <div class="relative">
                    <input type="text" name="Company" placeholder="COMPANY" class="w-full border-b border-gray-300 py-4 px-4 focus:outline-none focus:border-blue-500 text-xs placeholder-gray-400 bg-transparent">
                </div>
                <div class="relative">
                    <input type="text" name="Designation" placeholder="DESIGNATION" class="w-full border-b border-gray-300 py-4 px-4 focus:outline-none focus:border-blue-500 text-xs placeholder-gray-400 bg-transparent">
                </div>
                <div class="relative">
                    <input type="text" name="Mobile" required placeholder="MOBILE (WITH COUNTRY CODE) *" class="w-full border-b border-gray-300 py-4 px-4 focus:outline-none focus:border-blue-500 text-xs placeholder-gray-400 bg-transparent">
                </div>
                <div class="relative">
                    <input type="email" name="Email" required placeholder="EMAIL *" class="w-full border-b border-gray-300 py-4 px-4 focus:outline-none focus:border-blue-500 text-xs placeholder-gray-400 bg-transparent">
                </div>
                <div class="relative">
                    <select name="EnquiryType" required class="w-full border-b border-gray-300 py-4 px-4 focus:outline-none focus:border-blue-500 text-xs text-gray-400 bg-transparent">
                        <option value="" disabled selected>ENQUIRY TYPE *</option>
                        <option value="Quotation">Quotation</option>
                        <option value="Vendor Empanelment">Vendor Empanelment</option>
                        <option value="Technical">Technical</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <div class="md:col-span-2 relative">
                    <textarea name="ProjectDetails" required placeholder="PROJECT / PIPE SIZE / QUANTITY *" rows="3" class="w-full border-b border-gray-300 py-4 px-4 focus:outline-none focus:border-blue-500 text-xs placeholder-gray-400 bg-transparent resize-none"></textarea>
                </div>
                <div class="md:col-span-2 relative">
                    <textarea name="Message" placeholder="MESSAGE" rows="3" class="w-full border-b border-gray-300 py-4 px-4 focus:outline-none focus:border-blue-500 text-xs placeholder-gray-400 bg-transparent resize-none"></textarea>
                </div>
                
                <div class="md:col-span-2 relative py-2">
                    <!-- Premium reCAPTCHA Box -->
                    <div class="w-64 bg-gray-50 border border-gray-200 rounded-xl p-4 flex items-center justify-between shadow-sm">
                        <div class="flex items-center gap-3">
                            <input type="checkbox" required id="recaptcha_check" class="w-6 h-6 border-gray-300 rounded text-blue-600 focus:ring-blue-500 cursor-pointer">
                            <label for="recaptcha_check" class="text-xs text-gray-700 font-semibold cursor-pointer select-none">I'm not a robot</label>
                        </div>
                        <div class="flex flex-col items-center">
                            <img src="https://www.gstatic.com/recaptcha/api2/logo_48.png" alt="reCAPTCHA" class="w-8 h-8">
                            <span class="text-[8px] text-gray-400 mt-0.5">reCAPTCHA</span>
                        </div>
                    </div>
                </div>
                
                <div class="pt-4 md:col-span-2">
                    <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white rounded-xl w-full md:w-1/2 h-12 flex items-center justify-center shadow-lg transition duration-300 group">
                        <span class="text-[12px] font-bold uppercase tracking-wider flex items-center gap-2">
                            Submit Enquiry
                            <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                        </span>
                    </button>
                </div>
            </form>

            <!-- Prominent WhatsApp B2B Banner -->
            <div class="mt-12 p-8 bg-green-50 rounded-3xl border border-green-100 flex flex-col md:flex-row justify-between items-center gap-6 shadow-sm">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-2xl bg-green-500/10 flex items-center justify-center text-green-600 text-2xl">💬</div>
                    <div class="text-left">
                        <h4 class="font-bold text-lg text-green-900">Prefer Direct Contact?</h4>
                        <p class="text-sm text-green-700">For Indian B2B buyers, WhatsApp converts 5–10× faster than email forms.</p>
                    </div>
                </div>
                <a href="https://wa.me/919992177822" target="_blank" class="bg-green-500 hover:bg-green-600 text-white font-bold py-3.5 px-8 rounded-xl shadow-lg transition-colors flex items-center gap-2 text-sm uppercase tracking-wide group">
