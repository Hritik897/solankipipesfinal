            </div>

            <div class="flex flex-col items-center md:items-end">
                <h3 class="font-bold text-xs uppercase tracking-widest text-blue-900 mb-4">Follow Us</h3>
                <div class="flex space-x-4 mb-8">
                    <a href="https://facebook.com/solankipipes" target="_blank" class="text-gray-600 hover:text-blue-600"><i class="fab fa-facebook-f text-lg"></i></a>
                    <a href="https://instagram.com/solankipipes" target="_blank" class="text-gray-600 hover:text-blue-600"><i class="fab fa-instagram text-lg"></i></a>
                    <a href="https://linkedin.com/company/solanki-pipes" target="_blank" class="text-gray-600 hover:text-blue-600"><i class="fab fa-linkedin-in text-lg"></i></a>
