<%- include('partials/header') %>

<main class="bg-[#FDFBF7] min-h-screen font-sans">
    
    <!-- Hero Section with Background Accent -->
    <header class="py-12 px-6 text-center max-w-6xl mx-auto">
        <div class="inline-flex items-center gap-2 bg-emerald-50 border border-emerald-200 px-3 py-1 rounded-full text-emerald-800 text-xs font-bold tracking-wider uppercase mb-4">
            <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
            Community & Sustainability Initiative
        </div>
        <h1 class="text-3xl md:text-5xl lg:text-6xl font-light tracking-tight text-gray-900 uppercase">
            Sponsorship of <span class="font-extrabold text-[#1E3A8A]">Farmers’ Fair</span>
            <span class="block text-2xl md:text-4xl lg:text-5xl font-medium text-emerald-800 mt-2">& Agricultural Exhibition</span>
        </h1>
        <p class="mt-4 text-base md:text-lg font-medium text-gray-600 max-w-3xl mx-auto">
            Empowering the agricultural heartland of Haryana through advanced irrigation solutions, modern infrastructure education, and direct farmer support.
        </p>
    </header>

    <!-- Visual Showcase / Banner Grid -->
    <section class="max-w-6xl mx-auto px-6 mb-16">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-stretch">
            <!-- Left Side: Main Event Image -->
            <div class="lg:col-span-2 relative h-[350px] md:h-[450px] rounded-3xl overflow-hidden shadow-xl border border-gray-100 group">
                <img src="/images/197.jpg.jpeg" alt="Sponsorship of Farmers' Fair & Agricultural Exhibition" class="w-full h-full object-cover group-hover:scale-102 transition duration-700">
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
                <div class="absolute bottom-6 left-6 right-6">
                    <span class="bg-cyan-400 text-black text-xs font-bold px-3 py-1 rounded-md uppercase tracking-wider mb-2 inline-block">Official Event Coverage</span>
                    <h2 class="text-lg md:text-2xl font-bold text-white leading-tight">
                        Honourable Vice Chairman of Haryana addressing the gathering at the Solanki Pipes Pavilion
                    </h2>
                </div>
            </div>

            <!-- Right Side: Quick Factsheet Card -->
            <div class="bg-white border border-gray-100 rounded-3xl p-8 shadow-md flex flex-col justify-between relative overflow-hidden">
                <div class="absolute -right-16 -top-16 w-32 h-32 rounded-full bg-emerald-50/50"></div>
                <div class="relative">
                    <h3 class="text-xs uppercase font-extrabold tracking-widest text-[#1E3A8A] mb-4">Event Factsheet</h3>
                    <div class="space-y-6">
                        <div>
                            <span class="text-[10px] uppercase font-bold text-gray-400 block tracking-wider">Event Name</span>
                            <span class="text-sm font-semibold text-gray-800">Farmers’ Fair and Agricultural Exhibition</span>
                        </div>
                        <div>
                            <span class="text-[10px] uppercase font-bold text-gray-400 block tracking-wider">Region / State</span>
                            <span class="text-sm font-semibold text-gray-800">Rural Region of Haryana, India</span>
                        </div>
                        <div>
                            <span class="text-[10px] uppercase font-bold text-gray-400 block tracking-wider">Sponsored By</span>
                            <span class="text-sm font-bold text-[#1E3A8A]">Haryana Solanki Industries (Solanki Pipes)</span>
                        </div>
                        <div>
                            <span class="text-[10px] uppercase font-bold text-gray-400 block tracking-wider">Key Focus</span>
                            <span class="text-sm font-semibold text-emerald-800">Sustainable Irrigation, Water Conservation & Farmer Education</span>
                        </div>
                    </div>
                </div>

                <div class="mt-8 border-t border-gray-100 pt-6">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-full bg-emerald-50 flex items-center justify-center text-emerald-600">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                        </div>
                        <div>
                            <h4 class="text-xs font-bold text-gray-900">100% Quality Assured</h4>
                            <p class="text-[10px] text-gray-500 font-medium">IS 4984:2016 BIS-Licensed</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Main Content Sections Grid -->
    <section class="max-w-6xl mx-auto px-6 mb-16">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
            
            <!-- Left 2 Columns: Detailed Narrative -->
            <div class="lg:col-span-2 space-y-12">
                
                <!-- Event Overview -->
                <div class="bg-white rounded-3xl p-8 border border-gray-50 shadow-sm space-y-4">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-lg bg-emerald-100 flex items-center justify-center text-emerald-800 font-bold text-sm">01</div>
                        <h3 class="text-xl font-extrabold text-[#1E3A8A] uppercase tracking-wide">Event Overview</h3>
                    </div>
                    <hr class="border-gray-100">
                    <p class="text-gray-700 leading-relaxed text-base">
                        The primary objective of the Farmers’ Fair and Agricultural Exhibition was to introduce the rural farming communities of Haryana to state-of-the-art agricultural technologies, advanced irrigation solutions, and improved crop-management practices. Designed to bridge the gap between innovation and traditional farming, the exhibition acted as a robust educational platform for direct interaction, training, and knowledge-sharing.
                    </p>
                    <p class="text-gray-700 leading-relaxed text-base">
                        Farmers were introduced to automated sprinklers, high-durability HDPE pipes, water flow controllers, and soil preservation tools designed to boost overall crop yields while significantly conserving vital natural resources like water and power.
                    </p>
                </div>

                <!-- Distinguished Presence -->
                <div class="bg-white rounded-3xl p-8 border border-gray-50 shadow-sm space-y-4">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-lg bg-cyan-100 flex items-center justify-center text-cyan-800 font-bold text-sm">02</div>
                        <h3 class="text-xl font-extrabold text-[#1E3A8A] uppercase tracking-wide">Distinguished Presence</h3>
                    </div>
                    <hr class="border-gray-100">
                    <p class="text-gray-700 leading-relaxed text-base">
                        Adding profound prestige and state-level significance to the programme, the event was graced by the <strong>Honourable Vice Chairman of Haryana</strong>. He spent quality time interacting directly with the farming community, carefully listening to their localized challenges, irrigation issues, and infrastructure expectations.
                    </p>
                    <div class="bg-cyan-50/50 border border-cyan-100 rounded-2xl p-6 my-4 flex items-start gap-4">
                        <span class="text-cyan-800 text-3xl font-serif">“</span>
                        <p class="text-cyan-900 font-medium italic text-sm leading-relaxed">
                            During his address, the Vice Chairman emphasized that the modernization of rural agricultural infrastructure through sustainable technologies is key to doubling farmer income and safeguarding India's water resources for future generations. He lauded the active participation of manufacturing units in educating the rural workforce.
                        </p>
                    </div>
                </div>

                <!-- Our Contribution -->
                <div class="bg-white rounded-3xl p-8 border border-gray-50 shadow-sm space-y-6">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-lg bg-blue-100 flex items-center justify-center text-blue-800 font-bold text-sm">03</div>
                        <h3 class="text-xl font-extrabold text-[#1E3A8A] uppercase tracking-wide">Our Contribution</h3>
                    </div>
                    <hr class="border-gray-100">
                    <p class="text-gray-700 leading-relaxed text-base">
                        As a manufacturing unit deeply rooted in rural India, <strong>Solanki Industries</strong> is proud to lead initiatives that directly empower the farming community. Through our dedicated sponsorship and specialized pavilion, we demonstrated key technologies designed to redefine agricultural water transportation:
                    </p>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-2">
                        <!-- Tech Item 1 -->
                        <div class="flex gap-4 items-start">
                            <div class="w-10 h-10 rounded-full bg-emerald-50 flex items-center justify-center text-emerald-600 shrink-0">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
                                </svg>
                            </div>
                            <div>
                                <h4 class="font-bold text-gray-800 text-sm">Modern Irrigation Systems</h4>
                                <p class="text-xs text-gray-500 font-semibold mt-1">
                                    Demonstrating highly flexible HDPE sprinkler systems and robust PE-100 agricultural pipes suited for variable weather.
                                </p>
                            </div>
                        </div>

                        <!-- Tech Item 2 -->
                        <div class="flex gap-4 items-start">
                            <div class="w-10 h-10 rounded-full bg-blue-50 flex items-center justify-center text-blue-600 shrink-0">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12h4.5m1.5 0h1.5m1.5 0h7.5m-3 2.25h3m-3.75 3h7.5M2.25 6h19.5a2.25 2.25 0 012.25 2.25v9.75A2.25 2.25 0 0121.75 20.25H2.25A2.25 2.25 0 010 18V8.25A2.25 2.25 0 012.25 6z" />
                                </svg>
                            </div>
                            <div>
                                <h4 class="font-bold text-gray-800 text-sm">Efficient Water Management</h4>
                                <p class="text-xs text-gray-500 font-semibold mt-1">
                                    Showcasing leak-free jointing mechanisms and high-flow efficiency pipes that prevent costly water loss.
                                </p>
                            </div>
                        </div>

                        <!-- Tech Item 3 -->
                        <div class="flex gap-4 items-start">
                            <div class="w-10 h-10 rounded-full bg-amber-50 flex items-center justify-center text-amber-600 shrink-0">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" />
                                </svg>
                            </div>
                            <div>
                                <h4 class="font-bold text-gray-800 text-sm">Rural Development & Empowerment</h4>
                                <p class="text-xs text-gray-500 font-semibold mt-1">
                                    Providing direct access to affordable, premium, and certified plumbing pipes that withstand harsh terrains.
                                </p>
                            </div>
                        </div>

                        <!-- Tech Item 4 -->
                        <div class="flex gap-4 items-start">
                            <div class="w-10 h-10 rounded-full bg-rose-50 flex items-center justify-center text-rose-600 shrink-0">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.62 48.62 0 0112 20.9c2.785 0 5.5-.468 8.04-1.353.18-.06.377-.086.555-.053a9.071 9.071 0 005.524-1.353c-.156-2.12-.32-4.24-.492-6.347m-16.34 0c.055-.749.11-1.496.172-2.241a8.901 8.901 0 012.223-5.247A8.902 8.902 0 0112 2.25c2.785 0 5.3 1.277 6.96 3.284a8.902 8.902 0 012.223 5.248c.062.745.117 1.492.171 2.241m-16.34 0a48.57 48.57 0 0116.34 0" />
                                </svg>
                            </div>
                            <div>
                                <h4 class="font-bold text-gray-800 text-sm">Farmer Education Programmes</h4>
                                <p class="text-xs text-gray-500 font-semibold mt-1">
                                    Conducting live engineering demos on butt fusion jointing and high-impact pipe endurance.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <!-- Right Column: Interactive Banner & Brand Promise -->
            <div class="space-y-8">
                
                <!-- Commitment Spotlight Card -->
                <div class="bg-gradient-to-br from-[#1E3A8A] to-[#1E40AF] text-white rounded-3xl p-8 shadow-lg relative overflow-hidden">
                    <!-- Decorative Circle Backgrounds -->
                    <div class="absolute -left-12 -bottom-12 w-36 h-36 rounded-full bg-white/5"></div>
                    <div class="absolute -right-8 -top-8 w-24 h-24 rounded-full bg-cyan-400/10"></div>
                    
                    <span class="text-cyan-400 text-xs font-extrabold uppercase tracking-wider block mb-2">Our Promise</span>
                    <h4 class="text-2xl font-extrabold leading-tight">
                        Commitment to Farmers’ Future
                    </h4>
                    <hr class="border-white/10 my-4">
                    <p class="text-sm text-blue-100 leading-relaxed font-medium">
                        The farmers’ fair created deep awareness and opened brand-new pathways for empowering local growers and strengthening their future stability.
                    </p>
                    <p class="text-sm text-blue-100 leading-relaxed font-medium mt-4">
                        Solanki Pipes remains passionately dedicated to supporting the agricultural community and actively contributing to the long-term prosperity of farmers across Haryana.
                    </p>
                    
                    <div class="mt-8 flex items-center gap-2 text-cyan-400 text-xs font-bold tracking-wider uppercase">
                        <span>Cultivating Progress</span>
                        <span>•</span>
                        <span>Empowering Lives</span>
                    </div>
                </div>

                <!-- Secondary Gallery/Image showing Sachin Solanki or banner -->
                <div class="bg-white border border-gray-100 rounded-3xl p-6 shadow-sm space-y-4">
                    <h4 class="text-sm font-extrabold text-gray-800 uppercase tracking-wider">Corporate Leadership</h4>
                    <div class="rounded-2xl overflow-hidden h-48 bg-gray-100">
                        <img src="/images/IMG_0524.jpg.jpeg" alt="Corporate Leadership at Event" class="w-full h-full object-cover">
                    </div>
                    <p class="text-xs text-gray-500 leading-relaxed font-semibold">
                        Solanki Pipes Executive Team member interacting with community organizations, representing our dedication to corporate social responsibility (CSR) and agricultural extension services.
                    </p>
                </div>

            </div>

        </div>
        
        <!-- Bottom Impact Call-To-Action Banner -->
        <div class="mt-12 bg-emerald-800 text-white rounded-3xl p-8 md:p-10 text-center md:text-left flex flex-col md:flex-row items-center justify-between gap-6 relative overflow-hidden shadow-lg">
            <div class="absolute right-0 bottom-0 w-64 h-64 rounded-full bg-emerald-900/40 translate-x-12 translate-y-12"></div>
            <div class="max-w-2xl relative">
                <span class="text-emerald-300 text-xs font-extrabold uppercase tracking-wider">Join Hands For Sustainable Agriculture</span>
                <h4 class="text-2xl md:text-3xl font-extrabold mt-1 leading-tight">
                    Upgrade Your Irrigation Grids with IS-Certified Piping Configurations
                </h4>
                <p class="text-sm text-emerald-100 mt-2 font-medium">
                    Enquire today to receive customized technical support, wholesale supply schedules, and localized distribution details.
                </p>
            </div>
            <a href="/contact" class="bg-white hover:bg-emerald-50 text-emerald-900 px-6 py-3.5 font-bold rounded-xl text-sm transition uppercase whitespace-nowrap shadow-md relative shrink-0">
                Contact Our Irrigation Division
            </a>
        </div>
    </section>

    

</main>

<%- include('partials/footer') %>
