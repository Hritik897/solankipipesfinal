<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600&display=swap" rel="stylesheet">
    <title>
        <%= title %>
    </title>
    <meta name="description"
        content="Solanki Industries is a BIS-Licensed (IS 4984:2016) manufacturer of high-quality HDPE pipes in Haryana.">
    <meta property="og:title" content="<%= title %>">
    <meta property="og:description"
        content="Solanki Industries is a BIS-Licensed (IS 4984:2016) manufacturer of high-quality HDPE pipes in Haryana.">
    <meta property="og:type" content="website">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= title %>">
    <meta name="twitter:description"
        content="Solanki Industries is a BIS-Licensed (IS 4984:2016) manufacturer of high-quality HDPE pipes in Haryana.">
    <style>
        body {
            font-family: 'Montserrat', sans-serif;
        }

        .navbar-text {
            font-weight: 600;
            font-size: 12px;
            line-height: 24px;
            color: #000000;
        }

        .carousel-container {
            transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .hero-text {
            color: #0000FF;
            line-height: 1.1;
        }

        .scrollbar-hide::-webkit-scrollbar {
            display: none;
        }

        .scrollbar-hide {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }

        /* Slide-in Menu Logic */
        #mobile-menu {
            transition: transform 0.3s ease-in-out;
            transform: translateX(100%);
        }

        #mobile-menu.open {
            transform: translateX(0);
        }
    </style>
</head>

<body class="bg-[#FDFBF7] overflow-x-hidden max-w-7xl mx-auto">

    <header class="relative z-50 flex items-center justify-between px-6 md:px-10 py-2">
        <div class="flex items-center">
            <a href="/" class="block">
                <img src="/images/blacklogo.png" alt="Solanki Logo" class="h-12 md:h-16 w-auto object-contain">
            </a>
        </div>

        <nav class="hidden md:flex items-center space-x-10">
            <a href="/" class="navbar-text hover:text-blue-600 transition-colors">Home</a>
            <a href="/about" class="navbar-text hover:text-blue-600 transition-colors">About Us</a>

            <div class="relative group">
                <button class="navbar-text text-[#38BDF8] hover:text-blue-600 transition-colors flex items-center">
                    Products
                    <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                </button>

                <div
                    class="absolute left-0 mt-2 w-56 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-50 bg-white shadow-lg rounded-md py-2 border border-gray-100">
                    <a href="/hdpe" class="block px-4 py-3 text-gray-700 hover:bg-gray-50 hover:text-blue-600">HDPE
                        Water Pipe</a>

                    <a href="/dwc-pipe"
                        class="block px-4 py-3 text-gray-700 hover:bg-gray-50 hover:text-blue-600 flex items-center justify-between">
                        <span>DWC Pipe</span>
                        <span
                            class="bg-blue-100 text-blue-800 text-[10px] font-bold px-2 py-0.5 rounded-full">Soon</span>
                    </a>
                    <a href="/pvc-pipe" class="block px-4 py-3 text-gray-700 hover:bg-gray-50 hover:text-blue-600">PVC
                        Pipe</a>
                </div>
            </div>

            <a href="/projects" class="navbar-text hover:text-blue-600 transition-colors">Projects</a>
            <a href="/quality" class="navbar-text hover:text-blue-600 transition-colors">Quality</a>
            <a href="/contact" class="navbar-text hover:text-blue-600 transition-colors">Contact Us</a>

            <div class="w-6 h-6 rounded-full bg-gradient-to-tr from-[#57C1E8] to-[#6366F1]"></div>
        </nav>

        <button id="menu-btn" class="md:hidden flex flex-col space-y-1.5 focus:outline-none z-[60]">
            <span class="w-6 h-0.5 bg-black"></span>
            <span class="w-6 h-0.5 bg-black"></span>
            <span class="w-6 h-0.5 bg-black"></span>
        </button>
    </header>

    <div id="mobile-menu" class="fixed top-0 right-0 h-full w-72 bg-white shadow-2xl z-[55] flex flex-col md:hidden">
        <div class="flex justify-end p-6">
            <button id="close-btn" class="text-gray-500 hover:text-black focus:outline-none">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12">
                    </path>
                </svg>
            </button>
        </div>

        <div class="flex flex-col px-8 pb-8 overflow-y-auto">
            <a href="/"
                class="navbar-text text-base py-4 border-b border-gray-100 hover:text-blue-600 transition-colors">Home</a>
            <a href="/about"
                class="navbar-text text-base py-4 border-b border-gray-100 hover:text-blue-600 transition-colors">About
                Us</a>

            <div class="border-b border-gray-100">
                <button id="products-toggle"
                    class="w-full flex justify-between items-center py-4 navbar-text text-base text-[#38BDF8] focus:outline-none">
                    Products
                    <svg id="chevron-icon" class="w-4 h-4 transition-transform duration-300" fill="none"
                        stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                </button>

                <div id="products-list"
                    class="max-h-0 overflow-hidden transition-all duration-300 ease-in-out bg-gray-50 rounded-lg">
                    <div class="flex flex-col space-y-8 p-4">
                        <a href="/hdpe" class="text-xs font-semibold text-gray-600 hover:text-blue-600">HDPE Water
                            Pipe</a>

                        <a href="/dwc-pipe"
                            class="text-xs font-semibold text-gray-600 hover:text-blue-600 flex items-center justify-between">
                            <span>DWC Pipe</span>
                            <span
                                class="bg-blue-100 text-blue-800 text-[10px] font-bold px-2 py-0.5 rounded-full">Soon</span>
                        </a>
                        <a href="/pvc-pipe" class="text-xs font-semibold text-gray-600 hover:text-blue-600">PVC Pipe</a>
                    </div>
                </div>
            </div>

            <a href="/projects"
                class="navbar-text text-base py-4 border-b border-gray-100 hover:text-blue-600 transition-colors">Projects</a>
            <a href="/quality"
                class="navbar-text text-base py-4 border-b border-gray-100 hover:text-blue-600 transition-colors">Quality</a>
            <a href="/contact"
                class="navbar-text text-base py-4 border-b border-gray-100 hover:text-blue-600 transition-colors">Contact
                Us</a>

            <div class="mt-8 flex items-center space-x-3">
                <div class="w-6 h-6 rounded-full bg-gradient-to-tr from-[#57C1E8] to-[#6366F1]"></div>
                <span class="text-[10px] uppercase tracking-widest text-gray-400">Solanki Pipes</span>
            </div>
        </div>
    </div>

    <div id="menu-backdrop" class="fixed inset-0 bg-black/20 hidden z-[54] md:hidden"></div>

    <script>
        const btn = document.getElementById('menu-btn');
        const closeBtn = document.getElementById('close-btn');
        const menu = document.getElementById('mobile-menu');
        const backdrop = document.getElementById('menu-backdrop');
        const productsToggle = document.getElementById('products-toggle');
        const productsList = document.getElementById('products-list');
        const chevron = document.getElementById('chevron-icon');

        function toggleMenu() {
            menu.classList.toggle('open');
            backdrop.classList.toggle('hidden');
            // Prevent body scroll when menu is open
            document.body.style.overflow = menu.classList.contains('open') ? 'hidden' : '';
        }

        // Toggle Mobile Menu
        btn.addEventListener('click', toggleMenu);
        closeBtn.addEventListener('click', toggleMenu);
        backdrop.addEventListener('click', toggleMenu);

        // Accordion Logic for Products
        productsToggle.addEventListener('click', () => {
            const isOpen = productsList.style.maxHeight !== '0px' && productsList.style.maxHeight !== '';

            if (isOpen) {
                productsList.style.maxHeight = '0px';
                chevron.style.transform = 'rotate(0deg)';
            } else {
                //scrollHeight gives the exact height of the content
                productsList.style.maxHeight = productsList.scrollHeight + 'px';
                chevron.style.transform = 'rotate(180deg)';
            }
        });
    </script>