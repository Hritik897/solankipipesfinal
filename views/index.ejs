      <script>
        let currentHeroImage = 0;
        const totalHeroImages = 3;
        let heroInterval;

        const heroData = [
          {
            badge: "Welcome to Solanki Pipes",
            title: "Trusted Piping Partner for North India's <br class=\"hidden lg:block\" />\n<span class=\"text-transparent bg-clip-text bg-gradient-to-r from-blue-700 to-cyan-500\">Water Infrastructure</span>",
            description: "20+ Years of Manufacturing Excellence. Supplying high-quality PE 80 & PE 100 grades, PN 2.5 to PN 10 for a robust tomorrow."
          },
          {
            badge: "Unmatched Quality",
            title: "Advanced DWC Pipes for Reliable <br class=\"hidden lg:block\" />\n<span class=\"text-transparent bg-clip-text bg-gradient-to-r from-blue-700 to-cyan-500\">Underground Drainage</span>",
            description: "Engineered for superior load-bearing capacity and long life. The perfect solution for city sewage and industrial effluent disposal."
          },
          {
            badge: "Innovation & Durability",
            title: "High-Performance PVC Pipes for <br class=\"hidden lg:block\" />\n<span class=\"text-transparent bg-clip-text bg-gradient-to-r from-blue-700 to-cyan-500\">Every Application</span>",
            description: "From plumbing to agriculture, our PVC pipes offer unmatched strength, leak resistance, and eco-friendly performance."
          }
        ];

        function updateHeroImage() {
          const textContainer = document.getElementById('hero-text-container');
          if (textContainer) {
            textContainer.classList.remove('opacity-100');
            textContainer.classList.add('opacity-0');

            setTimeout(() => {
              const badgeEl = document.getElementById('hero-badge');
              const titleEl = document.getElementById('hero-title');
              const descEl = document.getElementById('hero-description');

              if (badgeEl) badgeEl.innerHTML = heroData[currentHeroImage].badge;
              if (titleEl) titleEl.innerHTML = heroData[currentHeroImage].title;
              if (descEl) descEl.innerHTML = heroData[currentHeroImage].description;

              textContainer.classList.remove('opacity-0');
              textContainer.classList.add('opacity-100');
            }, 300);
          }

          for (let i = 0; i < totalHeroImages; i++) {
            const img = document.getElementById(`hero-img-${i}`);
            const dot = document.getElementById(`hero-dot-${i}`);
            if (!img || !dot) continue;

            if (i === currentHeroImage) {
              img.classList.remove('opacity-0', 'scale-95', 'z-0', 'pointer-events-none');
              img.classList.add('opacity-100', 'scale-100', 'z-10');
              dot.classList.remove('bg-gray-300', 'w-2.5');
              dot.classList.add('bg-blue-600', 'w-8');
            } else {
              img.classList.remove('opacity-100', 'scale-100', 'z-10');
              img.classList.add('opacity-0', 'scale-95', 'z-0', 'pointer-events-none');
              dot.classList.remove('bg-blue-600', 'w-8');
              dot.classList.add('bg-gray-300', 'w-2.5');
            }
          }
        }

        function nextHeroImage() {
          currentHeroImage = (currentHeroImage + 1) % totalHeroImages;
          updateHeroImage();
        }

        function setHeroImage(index) {
          currentHeroImage = index;
          updateHeroImage();
          resetHeroInterval();
        }

        function resetHeroInterval() {
          clearInterval(heroInterval);
          heroInterval = setInterval(nextHeroImage, 3500); // Change image every 3.5 seconds
        }

        // Start interval on load
        window.addEventListener('DOMContentLoaded', () => {
          resetHeroInterval();
        });
      </script>