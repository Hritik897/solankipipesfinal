      <script>
        // Accordion toggle handler
        function toggleAccordion(id) {
          const content = document.getElementById(`content-${id}`);
          const icon = document.getElementById(`icon-${id}`);

          const isOpen = content.style.maxHeight !== '0px' && content.style.maxHeight !== '';

          // Close other active accordions to ensure neat toggle behavior
          const allContents = document.querySelectorAll("[id^='content-acc-']");
          const allIcons = document.querySelectorAll("[id^='icon-acc-']");

          allContents.forEach(c => {
            c.style.maxHeight = '0px';
          });

          allIcons.forEach(i => {
            i.style.transform = 'rotate(0deg)';
          });

          // Open the clicked accordion if it wasn't already open
          if (!isOpen) {
            content.style.maxHeight = content.scrollHeight + 'px';
            icon.style.transform = 'rotate(180deg)';
          }
        }

        // Open full-screen Zoom Modal
        function openZoomModal() {
          const modal = document.getElementById('zoom-modal');
          const modalContent = document.getElementById('zoom-modal-content');

          modal.classList.remove('hidden');
          modal.classList.add('flex');

          // Animate scaling with a tiny timeout to ensure display transitions trigger
          setTimeout(() => {
            modalContent.classList.remove('scale-95');
            modalContent.classList.add('scale-100');
          }, 10);

          document.body.style.overflow = 'hidden';
        }

        // Close Zoom Modal
        function closeZoomModal() {
          const modal = document.getElementById('zoom-modal');
          const modalContent = document.getElementById('zoom-modal-content');

          modalContent.classList.remove('scale-100');
          modalContent.classList.add('scale-95');

          setTimeout(() => {
            modal.classList.remove('flex');
            modal.classList.add('hidden');
            document.body.style.overflow = '';
          }, 200);
        }

        // Auto-expand the first accordion on load
        window.addEventListener('DOMContentLoaded', () => {
          setTimeout(() => {
            const firstContent = document.getElementById('content-acc-dhbvn');
            const firstIcon = document.getElementById('icon-acc-dhbvn');
            if (firstContent && firstIcon) {
              firstContent.style.maxHeight = firstContent.scrollHeight + 'px';
              firstIcon.style.transform = 'rotate(180deg)';
            }
          }, 250);
        });
      </script>


      <section id="typing-section" class="bg-[#3e4095] min-h-[40vh] flex items-center px-6 md:px-20 py-16 mb-16">
        <div class="max-w-5xl">
          <h1 class="text-3xl md:text-4xl lg:text-5xl text-cyan-300 leading-tight min-h-[120px] sm:min-h-[150px]">
            <span id="typing-text"></span><span id="typing-span" class="text-white/40"></span><span id="typing-cursor"
              class="inline-block w-[3px] h-[30px] md:h-[40px] lg:h-[48px] bg-cyan-300 ml-1 mb-[-4px] md:mb-[-6px] animate-pulse"></span>
          </h1>
        </div>
      </section>

      <script>
        document.addEventListener('DOMContentLoaded', () => {
          const textElement = document.getElementById('typing-text');
          const spanElement = document.getElementById('typing-span');
          const cursorElement = document.getElementById('typing-cursor');
          const section = document.getElementById('typing-section');

          const textPart1 = "Solanki Delivering Pipes for Diverse Industries, from Agriculture to Tele-communications, and Infrastructure Development, Building a Better ";
          const textPart2 = "Tomorrow.";

          let i = 0;
          let isTypingPart2 = false;
          let typingInterval;

          const observer = new IntersectionObserver((entries) => {
            if (entries[0].isIntersecting) {
              textElement.textContent = "";
              spanElement.textContent = "";
              i = 0;
              isTypingPart2 = false;

              typingInterval = setInterval(() => {
                if (!isTypingPart2) {
                  if (i < textPart1.length) {
                    textElement.textContent += textPart1.charAt(i);
                    i++;
                  } else {
                    isTypingPart2 = true;
                    i = 0;
                  }
                } else {
                  if (i < textPart2.length) {
                    spanElement.textContent += textPart2.charAt(i);
                    i++;
                  } else {
                    clearInterval(typingInterval);
                    setTimeout(() => {
                      cursorElement.classList.remove('animate-pulse');
                      cursorElement.style.opacity = '0';
                      cursorElement.style.transition = 'opacity 0.5s ease';
                    }, 2500); // Fade out cursor after 2.5 seconds
                  }
                }
              }, 40); // Typing speed in ms

              observer.unobserve(section); // Only animate once
            }
          }, { threshold: 0.3 }); // Trigger when 30% of the section is visible

          if (section) {
            observer.observe(section);
          }
        });
      </script>

